# ============================================
# AtlasRad Backend - Variables d'Environnement
# Copiez ce fichier en .env et modifiez les valeurs
# ============================================

# Clé secrète Django (changez impérativement en production !)
SECRET_KEY=atlasrad-super-secret-key-changez-moi-en-production-123456

# Mode développement
DEBUG=True

# Base de données (SQLite par défaut, PostgreSQL optionnel)
# Pour PostgreSQL décommentez et remplissez :
# DATABASE_URL=postgresql://user:password@localhost:5432/atlasrad_db

# Hôte autorisé
ALLOWED_HOSTS=localhost,127.0.0.1
