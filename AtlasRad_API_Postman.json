{
	"info": {
		"name": "AtlasRad API - Collection Postman",
		"description": "Collection complète pour tester l'API REST Django d'AtlasRad.\nBase URL: http://127.0.0.1:8000\n\n1. Inscrivez-vous via /api/auth/register\n2. Connectez-vous via /api/auth/login -> copiez le 'access' token\n3. Ajoutez le token dans Authorization: Bearer <token>\n4. Uploadez une image via /api/analyses/upload\n5. Lancez l'IA via /api/analyses/analyze",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. AUTH",
			"item": [
				{
					"name": "Inscription (Register)",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "http://127.0.0.1:8000/api/auth/register/"},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"sabir\",\n  \"email\": \"sabir@atlasrad.com\",\n  \"password\": \"SecurePass@123\",\n  \"password_confirm\": \"SecurePass@123\",\n  \"first_name\": \"Sabir\",\n  \"last_name\": \"Admin\",\n  \"hospital\": \"CHU Atlas\",\n  \"specialty\": \"Radiologie\"\n}"
						}
					}
				},
				{
					"name": "Connexion (Login)",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "http://127.0.0.1:8000/api/auth/login/"},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"sabir\",\n  \"password\": \"SecurePass@123\"\n}"
						}
					}
				},
				{
					"name": "Mon Profil (GET /me)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {"raw": "http://127.0.0.1:8000/api/auth/me/"}
					}
				},
				{
					"name": "Modifier mon Profil (PATCH /me)",
					"request": {
						"method": "PATCH",
						"header": [
							{"key": "Authorization", "value": "Bearer {{access_token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"url": {"raw": "http://127.0.0.1:8000/api/auth/me/"},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"hospital\": \"Clinique Al Andalous\",\n  \"specialty\": \"Neuro-Radiologie\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "2. ANALYSES",
			"item": [
				{
					"name": "Upload Image Médicale",
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {"raw": "http://127.0.0.1:8000/api/analyses/upload/"},
						"body": {
							"mode": "formdata",
							"formdata": [
								{"key": "image", "type": "file", "src": "/path/to/your/image.jpg"},
								{"key": "modality", "value": "CT", "type": "text"},
								{"key": "description", "value": "Scanner Cerebral Sans Injection", "type": "text"},
								{"key": "patient_id", "value": "AR-2026-0001", "type": "text"}
							]
						}
					}
				},
				{
					"name": "Analyser (Lancer IA)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{access_token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"url": {"raw": "http://127.0.0.1:8000/api/analyses/analyze/"},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"analysis_id\": 1\n}"
						}
					}
				},
				{
					"name": "Historique des Analyses",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
						"url": {
							"raw": "http://127.0.0.1:8000/api/analyses/history/?limit=10",
							"query": [
								{"key": "limit", "value": "10"},
								{"key": "modality", "value": "CT", "disabled": true},
								{"key": "status", "value": "completed", "disabled": true}
							]
						}
					}
				},
				{
					"name": "Dashboard Stats (Admin)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{admin_access_token}}"}],
						"url": {"raw": "http://127.0.0.1:8000/api/analyses/dashboard/stats/"}
					}
				}
			]
		}
	]
}
